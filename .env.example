# Copie para .env (não commite segredos reais)
# Imagem Docker: weblooks/auto-clear-wahagows (Docker Hub)
#
# --- WHATSAPP_SESSIONS_POSTGRESQL_URL ---
# Obrigatória. Mesma URL PostgreSQL que a WAHA Plus usa para sessões.
# A senha nunca aparece nos logs (fica mascarada).
WHATSAPP_SESSIONS_POSTGRESQL_URL=postgresql://user:password@host:5432/maindb?sslmode=disable

# --- Motor / nome do segmento no banco por sessão (minúsculas) ---
# Esta limpeza só atua na tabela gows_messages (engine GOWS). Alinhe com o container WAHA.
# Ordem neste serviço: (WHATSAPP_DEFAULT_ENGINE || WAHA_SESSION_NAMESPACE || WEBJS).toLowerCase()
WHATSAPP_DEFAULT_ENGINE=GOWS
# Só se precisar de paridade com WAHA que usa namespace explícito diferente do motor:
# WAHA_SESSION_NAMESPACE=

# --- Nomes das sessões a limpar (separados por vírgula) ---
# Obrigatório só sem WAHA_BASE_URL ou com WAHA_USE_SESSION_API=false.
# Com API ativa: não é fallback se a API falhar ou vier vazia — nesse caso o job não limpa nada.
SESSION_NAMES=default,session2

# Sessões a NUNCA limpar (lista separada por vírgula; comparação sem diferenciar maiúsculas/minúsculas).
# Aplica-se tanto a SESSION_NAMES quanto à lista vinda da API da WAHA (tem prioridade sobre o resto).
# Alias opcional: SESSION_NAMES_IGNORE (mesmo efeito)
# IGNORE_SESSION_NAMES=backup,readonly-session

# --- RETENTION_DAYS ---
# Dias de retenção global; o corte é “hoje menos N dias” (semântica de calendário).
RETENTION_DAYS=90

# --- Descoberta opcional de sessões na WAHA ---
# GET {WAHA_BASE_URL}/api/sessions?all=true com cabeçalho X-Api-Key (se definido)
# WAHA_BASE_URL=http://waha:3000
# WAHA_API_KEY=sua-chave-api
# false = força usar só SESSION_NAMES, mesmo com WAHA_BASE_URL definido
# WAHA_USE_SESSION_API=true

# --- Agendamento ---
# TZ: fuso horário do interpretador de cron (padrão UTC)
# CRON: expressão de 6 campos (segundo minuto hora dia mês dia-da-semana)
TZ=UTC
CRON=0 0 2 * * *

# true = executa um job logo ao iniciar o container, depois segue o CRON
# RUN_ON_START=false

# true = executa um único job e encerra (sem loop agendado; útil para cron no host ou CI)
# RUN_ONCE=false

# --- DRY_RUN ---
# true = só conta linhas (COUNT), sem DELETE
DRY_RUN=false

# Nível de log: debug | info | warn | error
# LOG_LEVEL=info
